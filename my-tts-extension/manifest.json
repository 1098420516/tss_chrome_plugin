{
  "manifest_version": 3,
  "name": "Local GPT-SoVITS Reader",
  "version": "1.0",
  "description": "使用本地GPT-SoVITS API克隆声音阅读网页内容",
  "permissions": ["contextMenus", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}